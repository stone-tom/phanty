DATABASE_URL=postgres://postgres:password@localhost:5432/phanty-db?sslmode=disable
API_PORT=4000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173

MAINTENANCE_MODE=false

# Comma-separated list of IPs that bypass maintenance mode (e.g. "127.0.0.1,10.0.0.1")
MAINTENANCE_IGNORE_IPS=

BETTER_AUTH_SECRET=supersecretkey
BETTER_AUTH_URL=http://localhost:4000
# Keep false in normal runtime. Seed command enables this temporarily.
ALLOW_SEED_SIGNUP=false

# Optional overrides for `pnpm --filter @repo/api auth:seed`
SEED_AUTH_NAME=Admin
SEED_AUTH_EMAIL=admin@phanty.app
SEED_AUTH_PASSWORD=change-me-please
