{
	"name": "phanty",
	"private": true,
	"packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
	"engines": {
		"node": ">=24.0.0"
	},
	"scripts": {
		"dev": "pnpm -r --parallel run dev",
		"build": "pnpm -r run build",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"format": "biome format --write .",
		"typecheck": "pnpm -r run typecheck",
		"db:seed": "pnpm --filter @repo/db db:seed",
		"atlas:diff": "pnpm --filter @repo/db atlas:diff",
		"atlas:rehash": "pnpm --filter @repo/db atlas:rehash",
		"atlas:apply": "pnpm --filter @repo/db atlas:apply",
		"atlas:status": "pnpm --filter @repo/db atlas:status"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"bun-types": "^1.3.10",
		"typescript": "^5.9.3"
	}
}
