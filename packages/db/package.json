{
	"name": "@repo/db",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		"./schema": "./src/schema/index.ts",
		"./types": "./src/types.ts"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"db:seed": "bun run src/seed/index.ts",
		"atlas:diff": "CI=true atlas migrate diff --env prod",
		"atlas:rehash": "CI=true atlas migrate hash --env prod",
		"atlas:apply": "CI=true atlas migrate apply --allow-dirty --env prod",
		"atlas:status": "CI=true atlas migrate status --env prod"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@repo/typescript": "workspace:*",
		"@types/bun": "^1.3.10",
		"drizzle-kit": "^0.31.9",
		"typescript": "^5.9.3"
	}
}
