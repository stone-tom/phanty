{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "lint:fix": {
      "cache": false
    },
    "check": {},
    "db:seed": {
      "cache": false,
      "inputs": ["src/**/*", ".env"]
    },
    "auth:generate": {
      "cache": false,
      "inputs": ["src/**/*", ".env"]
    },
    "atlas:diff": {
      "cache": false,
      "inputs": ["src/**/*", ".env"]
    },
    "atlas:apply": {
      "cache": false,
      "inputs": ["src/**/*", ".env"]
    },
    "atlas:status": {
      "cache": false,
      "inputs": ["src/**/*", ".env"]
    },
    "atlas:rollback": {
      "cache": false,
      "inputs": ["src/**/*", ".env"]
    },
    "atlas:rehash": {
      "cache": false,
      "inputs": ["src/**/*", ".env"]
    }
  }
}
