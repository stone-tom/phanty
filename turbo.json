{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx}",
        "biome.json",
        "../../biome.json"
      ],
      "outputs": []
    },
    "db:seed": {
      "cache": false,
      "inputs": [
        "src/**/*",
        ".env"
      ]
    },
    "auth:generate": {
      "cache": false,
      "inputs": [
        "src/**/*",
        ".env"
      ]
    },
    "atlas:diff": {
      "cache": false,
      "inputs": [
        "src/**/*",
        ".env"
      ]
    },
    "atlas:apply": {
      "cache": false,
      "inputs": [
        "src/**/*",
        ".env"
      ]
    },
    "atlas:status": {
      "cache": false,
      "inputs": [
        "src/**/*",
        ".env"
      ]
    },
    "atlas:rehash": {
      "cache": false,
      "inputs": [
        "src/**/*",
        ".env"
      ]
    },
    "lint:fix": {
      "cache": false,
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx}",
        "biome.json"
      ]
    }
  }
}